# Copy to .env for local development.
APP_ENV=development
APP_NAME=KSEB Bill Stats
PUBLIC_BASE_URL=http://localhost:8000

# Generate strong values before production.
APP_SECRET_KEY=change-me
FIELD_ENCRYPTION_KEY=j9K8hM9u2DLS4ikU3GQ4g3kc14i_Sa2SzVv-L2vFzRM=

# Database and storage
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/kseb
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/app/storage/objects

# Optional S3-compatible storage
S3_BUCKET=
S3_REGION=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Runtime
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=12
UPLOAD_MAX_MB=10
LOOKUP_RATE_LIMIT=10
LOOKUP_RATE_WINDOW_SECONDS=900
SYNC_CHECK_INTERVAL_MINUTES=60
WORKER_POLL_SECONDS=5
WORKER_NAME=worker-1
KSEB_TIMEOUT_SECONDS=30
KSEB_RUN_LIVE_VERIFICATION=true

# Browser push notifications
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_CONTACT=mailto:admin@example.com

TZ=Asia/Kolkata
